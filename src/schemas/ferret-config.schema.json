{
  "$ref": "#/definitions/FerretConfig",
  "definitions": {
    "FerretConfig": {
      "type": "object",
      "properties": {
        "severity": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "CRITICAL",
              "HIGH",
              "MEDIUM",
              "LOW",
              "INFO"
            ]
          }
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ignore": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 500
          },
          "maxItems": 100
        },
        "customRules": {
          "type": "string",
          "maxLength": 4096
        },
        "failOn": {
          "type": "string",
          "enum": [
            "CRITICAL",
            "HIGH",
            "MEDIUM",
            "LOW",
            "INFO"
          ]
        },
        "aiDetection": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "required": [
            "enabled"
          ],
          "additionalProperties": false
        },
        "threatIntelligence": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "feeds": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uri"
              },
              "maxItems": 20
            },
            "updateInterval": {
              "type": "string"
            }
          },
          "required": [
            "enabled"
          ],
          "additionalProperties": false
        },
        "behaviorAnalysis": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "patterns": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "maxItems": 100
            }
          },
          "required": [
            "enabled"
          ],
          "additionalProperties": false
        },
        "remediation": {
          "type": "object",
          "properties": {
            "autoFix": {
              "type": "boolean"
            },
            "quarantineDir": {
              "type": "string",
              "maxLength": 4096
            },
            "backupOriginals": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
